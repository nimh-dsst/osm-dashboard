# Ignore the virtual environment directory
.git
_version.py
dashboard_data
node_modules
venv/
.venv/
*coverage*
.idea
__pycache__/
*.pyc
*.pyo
*.pyd
# Secrets. `*.env` alone misses editor backups and suffixed variants
# (.secrets.env~, .env.local, .secrets.env.swp), which is a live risk in a
# public repo. Keep the tracked template exempt.
*.env
*.env~
*.env.*
!*.env.template
*.egg-info/
*.tfstate
dist/
build/
.tox/
venv/
.vscode/settings.json
.DS_Store
osm_output
.terraform
.terraform.lock.hcl
.public_dns
tempdata
.aider*
